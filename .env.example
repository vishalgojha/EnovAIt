NODE_ENV=development
PORT=8080

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini

OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=https://yourapp.example.com
OPENROUTER_APP_NAME=EnovAIt

WHATSAPP_BAILEYS_SESSION_PATH=.baileys_auth
WHATSAPP_META_ACCESS_TOKEN=your-meta-whatsapp-access-token
WHATSAPP_META_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_META_API_VERSION=v22.0
WHATSAPP_META_VERIFY_TOKEN=your-verify-token

LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

WEBHOOK_SIGNING_SECRET=replace-me
