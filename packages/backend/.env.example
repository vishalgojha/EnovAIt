NODE_ENV=development
PORT=8080

# Required for sign-in, tenant data, and platform access
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Choose one AI provider if you want the assistant features to work
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
AI_RETRY_ATTEMPTS=3
AI_RETRY_BASE_MS=400

# OpenAI or OpenAI-compatible provider
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1

# Anthropic provider
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# OpenRouter provider
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=https://yourapp.example.com
OPENROUTER_APP_NAME=EnovAIt

# WhatsApp and channel settings
WHATSAPP_BAILEYS_SESSION_PATH=.baileys_auth
EVOLUTION_API_BASE_URL=https://your-evolution-api.example.com
EVOLUTION_API_KEY=your-evolution-api-key
WHATSAPP_META_ACCESS_TOKEN=your-meta-whatsapp-access-token
WHATSAPP_META_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_META_API_VERSION=v22.0
WHATSAPP_META_VERIFY_TOKEN=your-verify-token
# WhatsApp webhook URL pattern: /api/v1/channels/whatsapp/official/webhook/:integrationId

# Other channels and notifications
SLACK_BOT_TOKEN=xoxb-xxx
SLACK_CHANNEL_DEFAULT=#ops-alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

MSTEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=mailer@example.com
EMAIL_SMTP_PASS=replace-me
EMAIL_FROM=EnovAIt <noreply@example.com>

# SMS and voice provider
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace-me
TWILIO_SMS_FROM=+10000000000
TWILIO_VOICE_FROM=+10000000000
TWILIO_VOICE_TWIML_URL=https://example.com/twiml/voice

# Optional IoT and enterprise system feeds
IOT_MQTT_URL=mqtt://broker.example.com:1883
IOT_MQTT_USERNAME=replace-me
IOT_MQTT_PASSWORD=replace-me
IOT_MQTT_TOPIC_DEFAULT=enovait/events

ERP_CRM_WEBHOOK_URL=https://erp.example.com/api/enovait/events
API_PARTNER_WEBHOOK_URL=https://partner.example.com/webhooks/enovait

# Archon orchestration settings
ARCHON_BASE_URL=http://127.0.0.1:8000
ARCHON_API_TOKEN=replace-me
ARCHON_TIMEOUT_MS=20000

# Webhook security
CHANNEL_WEBHOOK_TOKEN=replace-me
WEBHOOK_SIGNING_SECRET=replace-me

# Operational defaults
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
RATE_LIMIT_GLOBAL_MAX=240
RATE_LIMIT_TENANT_DEFAULT_MAX=120
RATE_LIMIT_TENANT_OVERRIDES_JSON={"org-uuid-1":300}
