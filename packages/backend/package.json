{
  "name": "enovait-backend",
  "version": "1.0.0",
  "description": "Production-ready backend for EnovAIt (Node.js + TypeScript + Supabase)",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build:server": "tsc -p tsconfig.json",
    "build:client": "vite build --outDir dist/client",
    "build": "npm run build:server && npm run build:client",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.57.0",
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@hookform/resolvers": "^3.10.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.52.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.99.2",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.6",
    "@vishalgojha/whatsapp-baileys-runtime": "github:vishalgojha/whatsapp-baileys-runtime",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.8.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "framer-motion": "^12.38.0",
    "helmet": "^8.0.0",
    "@google/genai": "^1.29.0",
    "jose": "^5.9.6",
    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "mqtt": "^5.10.4",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.5",
    "openai": "^4.85.4",
    "pdf-parse": "^2.4.3",
    "pino": "^9.6.0",
    "pino-http": "^10.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1",
    "shadcn": "^4.4.0",
    "sonner": "^1.7.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "vite": "^6.2.0",
    "xlsx": "^0.18.5",
    "xss": "^1.0.15",
    "zod": "^3.24.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.5",
    "@types/nodemailer": "^7.0.11",
    "@vitest/coverage-v8": "^4.1.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.1.3"
  }
}
