NODE_ENV=production
PORT=3000
TRUST_PROXY=1

# Supabase
SUPABASE_URL=your-supabase-url
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# AI Provider - Gemini (Primary)
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-2.0-flash

# AI Provider - Groq (Secondary)
GROQ_API_KEY=your-groq-key
GROQ_MODEL=llama-3.3-70b-versatile

# AI Provider - OpenRouter (Fallback)
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_MODEL=openrouter/free

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_GLOBAL_MAX=240
RATE_LIMIT_TENANT_DEFAULT_MAX=120

# Logging
LOG_LEVEL=info

# WhatsApp (Baileys)
WHATSAPP_BAILEYS_SESSION_PATH=/data/baileys
WHATSAPP_BAILEYS_DEFAULT_LABEL=primary

# Webhook
WEBHOOK_SIGNING_SECRET=
CHANNEL_WEBHOOK_TOKEN=
ENABLE_SUPER_ADMIN=false
