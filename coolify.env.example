NODE_ENV=production

# Coolify CLI
# Run without arguments for guided mode:
#   npx coolify
# Or use direct commands:
#   npx coolify env --name <resource-name> --file coolify.env --type application
#   npx coolify deploy --name <resource-name> --type application
#   npx coolify list --type application
COOLIFY_API_URL=http://coolify.example.com/api/v1
COOLIFY_API_TOKEN=your-coolify-api-token
COOLIFY_RESOURCE_TYPE=application
COOLIFY_RESOURCE_UUID=your-coolify-resource-uuid
COOLIFY_RESOURCE_NAME=enovait
COOLIFY_ENV_FILE=server-env.env

# Backend
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

AI_PROVIDER=groq
AI_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_SITE_URL=https://enov360.com
OPENROUTER_APP_NAME=EnovAIt
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

AI_RETRY_ATTEMPTS=3
AI_RETRY_BASE_MS=400
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_GLOBAL_MAX=240
RATE_LIMIT_TENANT_DEFAULT_MAX=120
RATE_LIMIT_TENANT_OVERRIDES={}
LOG_LEVEL=info

WHATSAPP_BAILEYS_SESSION_PATH=/data/baileys
EVOLUTION_API_BASE_URL=
EVOLUTION_API_KEY=
WHATSAPP_META_ACCESS_TOKEN=
WHATSAPP_META_PHONE_NUMBER_ID=
WHATSAPP_META_API_VERSION=v22.0
WHATSAPP_META_VERIFY_TOKEN=

SLACK_BOT_TOKEN=
SLACK_CHANNEL_DEFAULT=
SLACK_WEBHOOK_URL=
MSTEAMS_WEBHOOK_URL=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_VOICE_FROM=
TWILIO_VOICE_TWIML_URL=

IOT_MQTT_URL=
IOT_MQTT_USERNAME=
IOT_MQTT_PASSWORD=
IOT_MQTT_TOPIC_DEFAULT=enovait/sensors
ERP_CRM_WEBHOOK_URL=
API_PARTNER_WEBHOOK_URL=

CHANNEL_WEBHOOK_TOKEN=
WEBHOOK_SIGNING_SECRET=
ENABLE_SUPER_ADMIN=false

# Frontend build-time value
VITE_API_BASE_URL=https://api.enov360.com/api/v1
